{
  "centreon_api_url": "https://centreon.example.com",
  "centreon_api_token_file": "/etc/lgm-monitor/centreon_token.enc",
  "centreon_key_file": "/etc/lgm-monitor/key.bin",
  "centreon_username": "admin",
  "centreon_password": "centreon-password",
  "centreon_poller_name": "Central",
  "centreon_default_template": "generic-host",
  "centreon_hostgroup": "LGM",
  "receiver_port": 8443,
  "receiver_bind_address": "0.0.0.0",
  "log_level": "INFO",
  "verify_tls": true,
  "max_request_size_bytes": 262144,
  "db_path": "/var/lib/lgm-monitor/monitor.db",
  "agent_tokens": [],
  "agent_token_file": "/etc/lgm-monitor/agent_token.enc",
  "agent_key_file": "/etc/lgm-monitor/agent_key.bin",
  "hmac_enabled": true,
  "hmac_key_file": "/etc/lgm-monitor/hmac_key.bin",
  "hmac_secret_enc_file": "/etc/lgm-monitor/hmac_secret.enc",
  "hmac_max_skew_seconds": 300,
  "hmac_require_nonce": true,
  "hmac_nonce_ttl_seconds": 600,
  "nonce_cleanup_interval_seconds": 300,
  "sqlite_vacuum_interval_seconds": 86400,
  "latest_agent_version": "1.0.0",
  "latest_agent_download_url": "https://receiver.example.com/downloads/lgm-agent",
  "latest_agent_sha256": "PUT_SHA256_HERE"
}
